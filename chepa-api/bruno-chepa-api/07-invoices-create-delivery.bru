meta {
  name: Create Delivery Invoice
  type: http
  seq: 7
}

post {
  url: {{host}}/api/invoices/delivery
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "buyer_name": "{{buyerName}}",
    "items": [
      {
        "description": "Suzuki 150 Palanca de freno",
        "quantity": 2,
        "unit_price": 18500.00
      }
    ]
  }
}

assert {
  res.status: eq 201
}
