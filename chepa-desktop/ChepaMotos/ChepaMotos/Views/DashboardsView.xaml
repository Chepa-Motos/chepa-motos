<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChepaMotos.Views.DashboardsView">

    <Grid Padding="0" RowDefinitions="*">

        <Border Stroke="{StaticResource Border}"
                StrokeShape="RoundRectangle 0"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Surface}"
                Padding="0">
            <Grid>
                <WebView x:Name="MetabaseWebView"
                         Navigating="OnMetabaseNavigating"
                         Navigated="OnMetabaseNavigated" />

                <VerticalStackLayout x:Name="LoadingState"
                                     IsVisible="True"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8">
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource Accent}"
                                       WidthRequest="24"
                                       HeightRequest="24" />
                    <Label Text="Cargando dashboard de Metabase..."
                           FontFamily="IBMPlexSans"
                           FontSize="13"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="ErrorState"
                                     IsVisible="False"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Padding="20">
                    <Label Text="No se pudo cargar Metabase"
                           FontFamily="IBMPlexSansSemiBold"
                           FontSize="16"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                    <Label x:Name="ErrorText"
                           Text=""
                           FontFamily="IBMPlexSans"
                           FontSize="13"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center" />
                    <Button Text="Reintentar"
                            Clicked="OnRetryClicked"
                            Style="{StaticResource CtaAccentButton}" />
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>

</ContentView>
