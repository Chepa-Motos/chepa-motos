<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChepaMotos.Views.InvoicesView">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Page heading + date picker -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <Label Text="Facturas"
                       Style="{StaticResource PageHeading}" />
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 6"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="36"
                        Padding="0"
                        VerticalOptions="Center">
                    <DatePicker x:Name="FilterDatePicker"
                                Format="dd/MM/yyyy"
                                FontFamily="IBMPlexMono"
                                FontSize="13"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                MinimumDate="01/01/2024"
                                MaximumDate="12/31/2030"
                                DateSelected="OnDateSelected" />
                </Border>
            </Grid>

            <!-- Filter buttons row -->
            <HorizontalStackLayout Spacing="8">
                <Border x:Name="FilterAll"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource BorderStrong}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="12,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Todas" />
                    </Border.GestureRecognizers>
                    <Label Text="Todas" FontFamily="IBMPlexSansMedium" FontSize="13" TextColor="{StaticResource TextPrimary}" />
                </Border>
                <Border x:Name="FilterService"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource Border}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="12,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Servicio" />
                    </Border.GestureRecognizers>
                    <Label Text="Servicio" FontFamily="IBMPlexSansMedium" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border x:Name="FilterDelivery"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource Border}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="12,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Venta" />
                    </Border.GestureRecognizers>
                    <Label Text="Venta" FontFamily="IBMPlexSansMedium" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border x:Name="FilterCancelled"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource Border}"
                        BackgroundColor="{StaticResource Surface}"
                        Padding="12,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Anuladas" />
                    </Border.GestureRecognizers>
                    <Label Text="Anuladas" FontFamily="IBMPlexSansMedium" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </Border>

                <!-- Result count -->
                <Label x:Name="ResultCountLabel"
                       FontFamily="IBMPlexMono" FontSize="12"
                       TextColor="{StaticResource TextMuted}"
                       VerticalTextAlignment="Center"
                       Margin="8,0,0,0" />
            </HorizontalStackLayout>

            <!-- Invoices table -->
            <Border Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0">
                <VerticalStackLayout Spacing="0">

                    <!-- Header -->
                    <Grid ColumnDefinitions="60,80,120,120,100,100,80,80"
                          Padding="16,8"
                          BackgroundColor="{StaticResource Surface2}">
                        <Label Grid.Column="0" Text="#" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="1" Text="TIPO" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="2" Text="PLACA" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="3" Text="COMPRADOR" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="4" Text="MECÁNICO" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="5" Text="TOTAL" Style="{StaticResource TableHeader}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="6" Text="ESTADO" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="7" Text="HORA" Style="{StaticResource TableHeader}" HorizontalTextAlignment="End" />
                    </Grid>

                    <!-- Dynamic rows -->
                    <VerticalStackLayout x:Name="InvoiceRowsContainer" Spacing="0" />

                    <!-- Empty state -->
                    <Label x:Name="EmptyLabel"
                           Text="No hay facturas para esta fecha"
                           FontFamily="IBMPlexSans" FontSize="14"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           Padding="24,40"
                           IsVisible="False" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
