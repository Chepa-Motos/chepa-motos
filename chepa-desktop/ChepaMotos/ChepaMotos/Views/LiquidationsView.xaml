<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChepaMotos.ViewModels"
             x:Class="ChepaMotos.Views.LiquidationsView"
             x:DataType="vm:LiquidationsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Header: title + mechanic picker + date picker + reload + liquidate (GERENTE) -->
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
                <Label Text="Liquidaciones"
                       Style="{StaticResource PageHeading}"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 6"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="36"
                        Padding="10,0"
                        VerticalOptions="Center">
                    <Picker ItemsSource="{Binding MechanicOptions}"
                            ItemDisplayBinding="{Binding Name}"
                            SelectedItem="{Binding SelectedMechanicOption, Mode=TwoWay}"
                            FontFamily="IBMPlexSans"
                            FontSize="13"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextMuted}"
                            BackgroundColor="Transparent"
                            WidthRequest="200" />
                </Border>
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 6"
                        Stroke="{StaticResource Border}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}"
                        HeightRequest="36"
                        Padding="0"
                        VerticalOptions="Center">
                    <DatePicker x:Name="LiqDatePicker"
                                Date="{Binding SelectedDate, Mode=OneWay}"
                                Format="ddd dd/MM/yyyy"
                                FontFamily="IBMPlexMono"
                                FontSize="13"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                MinimumDate="2024-01-01"
                                MaximumDate="2030-12-31"
                                DateSelected="OnDateSelected" />
                </Border>
                <Button Grid.Column="3"
                        Text="↻"
                        Command="{Binding ReloadCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        FontSize="16"
                        WidthRequest="36"
                        HeightRequest="36"
                        Padding="0"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource Border}"
                        BorderWidth="1"
                        CornerRadius="6"
                        ToolTipProperties.Text="Recargar"
                        VerticalOptions="Center" />
                <Button Grid.Column="4"
                        Text="{Binding LiquidateButtonText}"
                        Command="{Binding LiquidateDayCommand}"
                        IsVisible="{Binding IsManager}"
                        IsEnabled="{Binding IsNotBusy}"
                        BackgroundColor="{StaticResource Amber}"
                        TextColor="{StaticResource White}"
                        FontFamily="IBMPlexSansSemiBold"
                        FontSize="13"
                        CornerRadius="6"
                        Padding="14,8"
                        MinimumHeightRequest="36"
                        VerticalOptions="Center" />
            </Grid>

            <!-- Error banner — solo en primera carga -->
            <Border IsVisible="{Binding IsError}"
                    BackgroundColor="{StaticResource AnuladaBg}"
                    Stroke="{StaticResource AnuladaText}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="14,12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="No se pudo cargar las liquidaciones"
                               FontFamily="IBMPlexSansSemiBold"
                               FontSize="13"
                               TextColor="{StaticResource AnuladaText}" />
                        <Label Text="{Binding LoadError}"
                               FontFamily="IBMPlexSans"
                               FontSize="12"
                               TextColor="{StaticResource AnuladaText}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Reintentar"
                            Command="{Binding ReloadCommand}"
                            BackgroundColor="{StaticResource AnuladaText}"
                            TextColor="{StaticResource White}"
                            FontFamily="IBMPlexSansSemiBold"
                            FontSize="12"
                            CornerRadius="6"
                            Padding="12,6"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Loading indicator (primera carga) -->
            <HorizontalStackLayout IsVisible="{Binding IsLoading}"
                                   Spacing="10"
                                   HorizontalOptions="Center"
                                   Padding="0,8">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="{StaticResource Accent}"
                                   WidthRequest="18"
                                   HeightRequest="18" />
                <Label Text="Cargando liquidaciones…"
                       FontFamily="IBMPlexSansMedium"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <!-- Summary cards -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Grid.Column="0"
                        Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}" Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total facturado" FontFamily="IBMPlexSans" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="SummaryTotalLabel" Text="{Binding SummaryTotalText}" FontFamily="IBMPlexMono" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Accent}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1"
                        Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}" Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total mecánicos" FontFamily="IBMPlexSans" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="SummaryMechanicLabel" Text="{Binding SummaryMechanicText}" FontFamily="IBMPlexMono" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Green}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="2"
                        Stroke="{StaticResource Border}" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        BackgroundColor="{StaticResource Surface}" Padding="16,14">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Total taller" FontFamily="IBMPlexSans" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label x:Name="SummaryShopLabel" Text="{Binding SummaryShopText}" FontFamily="IBMPlexMono" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Liquidations table -->
            <Border Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0">
                <VerticalStackLayout Spacing="0">

                    <!-- Header -->
                    <Grid ColumnDefinitions="120,*,80,120,120,120"
                          Padding="16,8"
                          BackgroundColor="{StaticResource Surface2}">
                        <Label Grid.Column="0" Text="FECHA" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="1" Text="MECÁNICO" Style="{StaticResource TableHeader}" />
                        <Label Grid.Column="2" Text="FACT." Style="{StaticResource TableHeader}" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="TOTAL" Style="{StaticResource TableHeader}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="4" Text="MECÁNICO (70%)" Style="{StaticResource TableHeader}" HorizontalTextAlignment="End" />
                        <Label Grid.Column="5" Text="TALLER (30%)" Style="{StaticResource TableHeader}" HorizontalTextAlignment="End" />
                    </Grid>

                          <!-- Dynamic rows -->
                          <CollectionView ItemsSource="{Binding LiquidationRows}"
                                 SelectionMode="None">
                           <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:LiquidationRowViewModel">
                                <VerticalStackLayout Spacing="0">
                                 <Grid ColumnDefinitions="120,*,80,120,120,120"
                                    Padding="16,10">
                                     <Label Grid.Column="0"
                                         Text="{Binding DateText}"
                                         FontFamily="IBMPlexMono"
                                         FontSize="13"
                                         TextColor="{StaticResource TextPrimary}"
                                         VerticalTextAlignment="Center" />

                                     <Label Grid.Column="1"
                                         Text="{Binding MechanicName}"
                                         FontFamily="IBMPlexSans"
                                         FontSize="13"
                                         TextColor="{StaticResource TextPrimary}"
                                         VerticalTextAlignment="Center" />

                                     <Label Grid.Column="2"
                                         Text="{Binding InvoiceCountText}"
                                         FontFamily="IBMPlexMono"
                                         FontSize="13"
                                         TextColor="{StaticResource TextPrimary}"
                                         VerticalTextAlignment="Center"
                                         HorizontalTextAlignment="Center" />

                                     <Label Grid.Column="3"
                                         Text="{Binding TotalRevenueText}"
                                         FontFamily="IBMPlexMono"
                                         FontSize="13"
                                         TextColor="{StaticResource TextPrimary}"
                                         VerticalTextAlignment="Center"
                                         HorizontalTextAlignment="End" />

                                     <Label Grid.Column="4"
                                         Text="{Binding MechanicShareText}"
                                         FontFamily="IBMPlexMono"
                                         FontSize="13"
                                         TextColor="{StaticResource Green}"
                                         VerticalTextAlignment="Center"
                                         HorizontalTextAlignment="End" />

                                     <Label Grid.Column="5"
                                         Text="{Binding ShopShareText}"
                                         FontFamily="IBMPlexMono"
                                         FontSize="13"
                                         TextColor="{StaticResource TextPrimary}"
                                         VerticalTextAlignment="Center"
                                         HorizontalTextAlignment="End" />
                                 </Grid>

                                 <BoxView HeightRequest="1" Color="{StaticResource Border}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                           </CollectionView.ItemTemplate>
                          </CollectionView>

                    <!-- Empty state -->
                    <Label x:Name="EmptyLabel"
                              IsVisible="{Binding IsEmpty}"
                           Text="No hay liquidaciones para esta fecha"
                           FontFamily="IBMPlexSans" FontSize="14"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           Padding="24,40"
                              />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
