<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChepaMotos.ViewModels"
             x:Class="ChepaMotos.Views.MechanicsView"
             x:DataType="vm:MechanicsViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <Label Text="Mecánicos"
                       Style="{StaticResource PageHeading}"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="↻"
                        Command="{Binding ReloadCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        FontSize="16"
                        WidthRequest="36"
                        HeightRequest="36"
                        Padding="0"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource Border}"
                        BorderWidth="1"
                        CornerRadius="6"
                        ToolTipProperties.Text="Recargar"
                        VerticalOptions="Center" />
                <Button Grid.Column="2"
                        Text="+ Nuevo mecánico"
                        Style="{StaticResource CtaAccentButton}"
                        IsVisible="{Binding IsManager}"
                        Clicked="OnAddMechanicClicked" />
            </Grid>

            <!-- Error banner — solo en primera carga -->
            <Border IsVisible="{Binding IsError}"
                    BackgroundColor="{StaticResource AnuladaBg}"
                    Stroke="{StaticResource AnuladaText}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="14,12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="No se pudo cargar los mecánicos"
                               FontFamily="IBMPlexSansSemiBold"
                               FontSize="13"
                               TextColor="{StaticResource AnuladaText}" />
                        <Label Text="{Binding LoadError}"
                               FontFamily="IBMPlexSans"
                               FontSize="12"
                               TextColor="{StaticResource AnuladaText}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="Reintentar"
                            Command="{Binding ReloadCommand}"
                            BackgroundColor="{StaticResource AnuladaText}"
                            TextColor="{StaticResource White}"
                            FontFamily="IBMPlexSansSemiBold"
                            FontSize="12"
                            CornerRadius="6"
                            Padding="12,6"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Loading indicator (primera carga) -->
            <HorizontalStackLayout IsVisible="{Binding IsLoading}"
                                   Spacing="10"
                                   HorizontalOptions="Center"
                                   Padding="0,8">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="{StaticResource Accent}"
                                   WidthRequest="18"
                                   HeightRequest="18" />
                <Label Text="Cargando mecánicos…"
                       FontFamily="IBMPlexSansMedium"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>

            <!-- Summary -->
            <Label x:Name="SummaryLabel"
                     Text="{Binding SummaryText}"
                   FontFamily="IBMPlexMono" FontSize="12"
                   TextColor="{StaticResource TextMuted}" />

            <!-- Mechanics list -->
            <Border Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0">
                <Grid>
                    <CollectionView ItemsSource="{Binding Mechanics}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MechanicRowViewModel">
                                <VerticalStackLayout Spacing="0">
                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                          Padding="16,14"
                                          Opacity="{Binding RowOpacity}">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="IBMPlexSansMedium"
                                                   FontSize="14"
                                                   TextColor="{StaticResource TextPrimary}" />
                                            <Label Text="{Binding Subtitle}"
                                                   FontFamily="IBMPlexMono"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextMuted}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                StrokeShape="RoundRectangle 4"
                                                StrokeThickness="0"
                                                BackgroundColor="{Binding BadgeBackgroundColor}"
                                                Padding="8,2"
                                                VerticalOptions="Center"
                                                Margin="0,0,12,0">
                                            <Label Text="{Binding BadgeText}"
                                                   FontFamily="IBMPlexSansMedium"
                                                   FontSize="11"
                                                   TextColor="{Binding BadgeTextColor}" />
                                        </Border>

                                        <Switch Grid.Column="2"
                                                IsToggled="{Binding IsActive}"
                                                IsEnabled="{Binding CanToggle}"
                                                VerticalOptions="Center"
                                                Toggled="OnMechanicToggled" />
                                    </Grid>

                                    <BoxView HeightRequest="1"
                                             Color="{StaticResource Border}" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty state -->
                    <Label x:Name="EmptyLabel"
                           IsVisible="{Binding IsEmpty}"
                           Text="No hay mecánicos registrados"
                           FontFamily="IBMPlexSans" FontSize="14"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalTextAlignment="Center"
                           Padding="24,40"
                           />
                </Grid>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
