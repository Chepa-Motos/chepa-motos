<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ChepaMotos.Views.MechanicsView">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Grid ColumnDefinitions="*,Auto">
                <Label Text="Mecánicos"
                       Style="{StaticResource PageHeading}" />
                <Button Grid.Column="1"
                        Text="+ Nuevo mecánico"
                        Style="{StaticResource CtaAccentButton}"
                        Clicked="OnAddMechanicClicked" />
            </Grid>

            <!-- Summary -->
            <Label x:Name="SummaryLabel"
                   FontFamily="IBMPlexMono" FontSize="12"
                   TextColor="{StaticResource TextMuted}" />

            <!-- Mechanics list -->
            <Border Stroke="{StaticResource Border}"
                    StrokeShape="RoundRectangle 8"
                    StrokeThickness="1"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0">
                <VerticalStackLayout x:Name="MechanicsContainer" Spacing="0" />

                <!-- Empty state -->
                <Label x:Name="EmptyLabel"
                       Text="No hay mecanicos registrados"
                       FontFamily="IBMPlexSans" FontSize="14"
                       TextColor="{StaticResource TextMuted}"
                       HorizontalTextAlignment="Center"
                       Padding="24,40"
                       IsVisible="False" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentView>
