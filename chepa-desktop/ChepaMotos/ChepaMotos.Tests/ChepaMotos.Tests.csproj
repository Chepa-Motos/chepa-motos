		<Compile Include="..\ChepaMotos\Services\Domain\IMechanicService.cs" Link="LinkedSource\Services\Domain\IMechanicService.cs" />
		<Compile Include="..\ChepaMotos\Services\Domain\MechanicService.cs" Link="LinkedSource\Services\Domain\MechanicService.cs" />
		<Compile Include="..\ChepaMotos\Services\Domain\IInvoiceService.cs" Link="LinkedSource\Services\Domain\IInvoiceService.cs" />
